# Server
PORT=8080
NODE_ENV=production

# JWT — production uchun 32+ belgili random string
JWT_SECRET=change-this-to-a-random-32char-string-in-production
JWT_EXPIRES_IN=7d

# CORS — Vercel URL'lari, vergul bilan
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Neon PostgreSQL (pooled URL — runtime uchun)
DATABASE_URL=postgresql://USER:PASS@HOST-pooler.NEON_REGION.aws.neon.tech/DB?sslmode=require

# Direct URL (migratsiya uchun — ixtiyoriy, Neon'da odatda pooled URL ham ishlaydi)
# DIRECT_URL=postgresql://USER:PASS@HOST.NEON_REGION.aws.neon.tech/DB?sslmode=require
