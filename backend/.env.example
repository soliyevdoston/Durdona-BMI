# Server
PORT=8080
NODE_ENV=production

# JWT — PRODUCTION uchun 32+ belgi random string kiriting
JWT_SECRET=change-this-to-a-random-32char-string-in-production
JWT_EXPIRES_IN=7d

# CORS — vergul bilan ajratib yozing. Vercel URL'larini qo'shing.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,https://student-app.vercel.app,https://teacher-app.vercel.app,https://admin-app.vercel.app
